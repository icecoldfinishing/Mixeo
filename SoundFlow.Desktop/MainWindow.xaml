<Window x:Class="SoundFlow.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SoundFlow Watcher"
        Height="600"
        Width="900">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <Button Name="SelectFolder"
                    Height="40"
                    Click="SelectFolder_Click">
                Choisir dossier MP3
            </Button>

            <TextBlock Name="FolderText"
                       Margin="0,10,0,10"/>
        </StackPanel>

        <DataGrid Name="Mp3Grid"
                  Grid.Row="1"
                  AutoGenerateColumns="True"/>

    </Grid>

</Window>