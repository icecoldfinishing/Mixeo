<Window x:Class="Mixeo.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mixeo — Scan répertoire"
        Height="620" Width="900"
        MinHeight="500" MinWidth="700"
        Background="#0F1117"
        FontFamily="Segoe UI">

    <Window.Resources>
        <!-- Couleurs -->
        <SolidColorBrush x:Key="BgPrimary"     Color="#0F1117"/>
        <SolidColorBrush x:Key="BgSurface"     Color="#1A1D27"/>
        <SolidColorBrush x:Key="BgRow"         Color="#1E2130"/>
        <SolidColorBrush x:Key="BgRowAlt"      Color="#1A1D27"/>
        <SolidColorBrush x:Key="AccentBlue"    Color="#4F8EF7"/>
        <SolidColorBrush x:Key="AccentGreen"   Color="#3DD68C"/>
        <SolidColorBrush x:Key="TextPrimary"   Color="#E8EAF0"/>
        <SolidColorBrush x:Key="TextMuted"     Color="#6B7280"/>
        <SolidColorBrush x:Key="Border"        Color="#2A2D3E"/>

        <!-- Bouton principal -->
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background"   Value="#4F8EF7"/>
            <Setter Property="Foreground"   Value="White"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Padding"      Value="18,9"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3A7AE8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#2D6DD4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DataGrid -->
        <Style TargetType="DataGrid">
            <Setter Property="Background"            Value="Transparent"/>
            <Setter Property="Foreground"            Value="#E8EAF0"/>
            <Setter Property="BorderThickness"       Value="0"/>
            <Setter Property="GridLinesVisibility"   Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#2A2D3E"/>
            <Setter Property="RowBackground"         Value="#1E2130"/>
            <Setter Property="AlternatingRowBackground" Value="#1A1D27"/>
            <Setter Property="ColumnHeaderHeight"    Value="38"/>
            <Setter Property="RowHeight"             Value="36"/>
            <Setter Property="FontSize"              Value="13"/>
            <Setter Property="SelectionMode"         Value="Single"/>
            <Setter Property="SelectionUnit"         Value="FullRow"/>
            <Setter Property="AutoGenerateColumns"   Value="False"/>
            <Setter Property="CanUserAddRows"        Value="False"/>
            <Setter Property="CanUserDeleteRows"     Value="False"/>
            <Setter Property="IsReadOnly"            Value="True"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"   Value="#141720"/>
            <Setter Property="Foreground"   Value="#6B7280"/>
            <Setter Property="FontSize"     Value="11"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Padding"      Value="12,0"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush"  Value="#2A2D3E"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding"          Value="12,0"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#2A3A5E"/>
                    <Setter Property="Foreground" Value="#E8EAF0"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridRow">
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#2A3A5E"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#232638"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ScrollBar discret -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>   <!-- Header -->
            <RowDefinition Height="Auto"/> <!-- Toolbar -->
            <RowDefinition Height="*"/>    <!-- Contenu principal -->
            <RowDefinition Height="Auto"/> <!-- Détail fichier sélectionné -->
            <RowDefinition Height="28"/>   <!-- Barre de statut -->
        </Grid.RowDefinitions>

        <!-- ═══ HEADER ═══ -->
        <Border Grid.Row="0" Background="#141720"
                BorderThickness="0,0,0,1" BorderBrush="#2A2D3E">
            <Grid Margin="20,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="10" Height="10" Fill="#4F8EF7" Margin="0,0,10,0"/>
                    <TextBlock Text="M I X E O" FontSize="15" FontWeight="Bold"
                               Foreground="#E8EAF0"/>
                    <TextBlock Text="  /  Scan répertoire" FontSize="13"
                               Foreground="#6B7280" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ TOOLBAR ═══ -->
        <Border Grid.Row="1" Background="#1A1D27"
                BorderThickness="0,0,0,1" BorderBrush="#2A2D3E"
                Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" x:Name="SelectFolderBtn"
                        Content="📁  Choisir un répertoire"
                        Style="{StaticResource BtnPrimary}"
                        Click="SelectFolder_Click"/>

                <Border Grid.Column="1" Margin="14,0"
                        Background="#0F1117" CornerRadius="6"
                        BorderThickness="1" BorderBrush="#2A2D3E"
                        Padding="12,0">
                    <TextBlock x:Name="FolderText"
                               Text="Aucun répertoire sélectionné"
                               Foreground="#6B7280" FontSize="13"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
                </Border>

                <!-- Badge compteur -->
                <Border Grid.Column="2" Background="#1E2130"
                        CornerRadius="6" Padding="12,6"
                        BorderThickness="1" BorderBrush="#2A2D3E">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Fichiers : " Foreground="#6B7280" FontSize="12"/>
                        <TextBlock x:Name="FileCountText" Text="0"
                                   Foreground="#4F8EF7" FontSize="12" FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ═══ GRILLE PRINCIPALE ═══ -->
        <DataGrid Grid.Row="2" x:Name="Mp3Grid" Margin="0"
                  SelectionChanged="Mp3Grid_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="TITRE"    Binding="{Binding Title}"    Width="*"   MinWidth="140"/>
                <DataGridTextColumn Header="ARTISTE"  Binding="{Binding Artist}"   Width="160"/>
                <DataGridTextColumn Header="ALBUM"    Binding="{Binding Album}"    Width="160"/>
                <DataGridTextColumn Header="GENRE"    Binding="{Binding Genre}"    Width="100"/>
                <DataGridTextColumn Header="ANNÉE"    Binding="{Binding Year}"     Width="70"/>
                <DataGridTextColumn Header="DURÉE"    Binding="{Binding Duration}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- ═══ PANNEAU DÉTAIL ═══ -->
        <Border Grid.Row="3" Background="#141720"
                BorderThickness="0,1,0,0" BorderBrush="#2A2D3E"
                Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="80"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Titre" Foreground="#6B7280" FontSize="11" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" x:Name="TitleText"  Foreground="#E8EAF0" FontSize="13" Margin="6,0,20,0" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>

                <TextBlock Grid.Column="2" Text="Artiste" Foreground="#6B7280" FontSize="11" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="3" x:Name="ArtistText" Foreground="#E8EAF0" FontSize="13" Margin="6,0,20,0" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>

                <TextBlock Grid.Column="4" Text="Album" Foreground="#6B7280" FontSize="11" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="5" x:Name="AlbumText"  Foreground="#E8EAF0" FontSize="13" Margin="6,0,20,0" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>

                <TextBlock Grid.Column="6" Text="Genre" Foreground="#6B7280" FontSize="11" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="7" x:Name="GenreText"  Foreground="#E8EAF0" FontSize="13" Margin="6,0,20,0" VerticalAlignment="Center"/>

                <TextBlock Grid.Column="8" Text="Durée" Foreground="#6B7280" FontSize="11" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="9" x:Name="DurationText" Foreground="#3DD68C" FontSize="13" FontWeight="SemiBold" Margin="6,0,0,0" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ═══ BARRE DE STATUT ═══ -->
        <Border Grid.Row="4" Background="#0C0E14"
                BorderThickness="0,1,0,0" BorderBrush="#2A2D3E"
                Padding="20,0">
            <Grid>
                <TextBlock x:Name="StatusText"
                           Text="Prêt — choisissez un répertoire pour commencer."
                           Foreground="#4B5160" FontSize="11"
                           VerticalAlignment="Center"/>
                <TextBlock Text="Scan auto toutes les 60 s"
                           Foreground="#4B5160" FontSize="11"
                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
