<Window x:Class="Mixeo.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mixeo" Height="600" Width="900">

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal">
            <Button Content="Choisir dossier"
                    Click="SelectFolder_Click"
                    Width="150"/>

            <TextBlock Name="FolderText"
                       Margin="10,0,0,0"
                       VerticalAlignment="Center"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- LISTE MP3 -->
            <DataGrid Name="Mp3Grid"
                      AutoGenerateColumns="True"
                      SelectionChanged="Mp3Grid_SelectionChanged"/>

            <!-- DETAILS -->
            <StackPanel Grid.Column="1" Margin="10">
                <TextBlock Text="METADATA" FontWeight="Bold"/>

                <TextBlock Text="Title:"/>
                <TextBlock Name="TitleText"/>

                <TextBlock Text="Album:"/>
                <TextBlock Name="AlbumText"/>

                <TextBlock Text="Artist:"/>
                <TextBlock Name="ArtistText"/>

                <TextBlock Text="Genre:"/>
                <TextBlock Name="GenreText"/>

                <TextBlock Text="Year:"/>
                <TextBlock Name="YearText"/>

                <TextBlock Text="Duration:"/>
                <TextBlock Name="DurationText"/>
            </StackPanel>

        </Grid>
    </Grid>
</Window>