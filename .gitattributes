# Ignorer complètement TypeScript (fichiers .ts et .tsx) des statistiques
*.ts linguist-vendored
*.tsx linguist-vendored

# Ignorer également les fichiers de build JavaScript générés
*.js linguist-vendored
*.js.map linguist-vendored
node_modules/* linguist-vendored
dist/* linguist-vendored
build/* linguist-vendored

# Forcer l'analyse exclusive du C#
*.cs linguist-language=C#
